# Option A — local PostgreSQL on port 5432 (no Docker; run scripts/setup_local_db.ps1 first)
DATABASE_URL=postgresql://icps:icps_secret@127.0.0.1:5432/icps_master

# Option B — Docker PostgreSQL on port 5434 (requires Docker Desktop running)
# DATABASE_URL=postgresql://icps:icps_secret@127.0.0.1:5434/icps_master

# Option C — Neon cloud (free, no Docker or local Postgres setup)
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/icps_master?sslmode=require

PORT=8000

# Seller workflow / MQTT
MQTT_ENABLED=true
MQTT_BROKER=207.246.121.211
MQTT_PORT=1883
MQTT_QOS=1
MQTT_CLIENT_ID=icps-seller-sim
MQTT_SUBSCRIBE_TOPIC=rfid/1514032003830/1514250054321/edi/850
MQTT_ACK_TOPIC=rfid/1514250054321/1514032003830/edi/855
MQTT_ASN_TOPIC=rfid/1514250054321/1514032003830/edi/856

SELLER_GLN=1514250054321
SELLER_NAME=ICPS-Lab
BUYER_GLN=1514032003830
BUYER_NAME=IoT-Lab

# Fulfillment: immediate | scheduled | simulated
FULFILLMENT_MODE=simulated
FULFILLMENT_DELAY_SECONDS=5
DEFAULT_CARRIER=FedEx
